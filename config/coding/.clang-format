# .clang-format for BARR-C:2018 / Embedded C
---
Language: Cpp
BasedOnStyle: LLVM

# --- Section 1: Indentation & Tabs (Rule 1.3) ---
# BARR-C 1.3.a: "Indentation shall be 4 spaces."
# BARR-C 1.3.b: "The tab character shall not be used."
IndentWidth: 4
UseTab: Never
ContinuationIndentWidth: 4

# --- Section 2: Line Width (Rule 1.2) ---
ColumnLimit: 120

# --- Section 3: Braces & Control Structures (Rule 4.2 & 1.1) ---
# BARR-C 4.1.f/4.2.a: "Braces shall always surround blocks of code." 
# (Even for single-line if/for/while statements)
BreakBeforeBraces: Allman
AllowShortBlocksOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: false
AllowShortLoopsOnASingleLine: false
Cpp11BracedListStyle: false

# --- Section 4: Whitespace & Parentheses (Rule 1.1) ---
# BARR-C 1.1.f: "A space shall follow each comma and semicolon."
# BARR-C 1.1.g: "A space shall separate every binary operator."
SpaceBeforeParens: ControlStatements
SpaceAfterCStyleCast: true
SpacesInParentheses: false
SpaceBeforeAssignmentOperators: true
SpaceBeforeRangeBasedForLoopColon: true
SpaceInEmptyParentheses: false

# --- Section 5: Switch Statements (Rule 4.1) ---
# BARR-C 4.1.a: "Switch statements shall be formatted as follows..."
IndentCaseLabels: true
IndentCaseBlocks: false

# --- Section 6: Pointers & Declarations (Rule 2.2) ---
# BARR-C 2.2.b: "The * shall be adjacent to the name."
PointerAlignment: Right
AlignConsecutiveMacros: true
AlignConsecutiveDeclarations: true

# --- Section 7: Includes & Cleanup ---
# BARR-C 1.5: While BARR-C doesn't mandate sorting,
# keeping it false prevents unexpected re-ordering of hardware headers.
SortIncludes: false
MaxEmptyLinesToKeep: 1
KeepEmptyLinesAtTheStartOfBlocks: false

# --- Section 8: Formatting Behavior ---
AlignAfterOpenBracket: Align
AlwaysBreakAfterReturnType: None
PenaltyReturnTypeOnItsOwnLine: 60
BreakBeforeBinaryOperators: None
IndentExternBlock: NoIndent
BinPackArguments: false
BinPackParameters: false
InsertBraces: true
